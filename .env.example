# Search fallback (frontend users can provide this per run)
SERPER_API_KEY=

# Excel output
EXCEL_OUTPUT_PATH=outputs/event-intelligence-results.xlsx

# AI fallback (frontend users can provide NVIDIA per run)
NVIDIA_API_KEY=
NVIDIA_MODEL=openai/gpt-oss-120b
ANTHROPIC_API_KEY=

# Local frontend
PORT=3000

# Processing
CONCURRENCY=1
MAX_SEARCH_RESULTS=10
PAGE_LOAD_TIMEOUT=30000
NETWORK_IDLE_WAIT=5000
HEADLESS=true

# Logging
LOG_LEVEL=info
