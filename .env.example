# Search key is server-managed
SERPER_API_KEY=

# Excel output
EXCEL_OUTPUT_PATH=outputs/event-intelligence-results.xlsx

# AI fallback key may be entered in frontend per run; model is fixed in code
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=

# Gmail read-only automation via Google Workspace domain-wide delegation
GMAIL_SERVICE_ACCOUNT_EMAIL=
GMAIL_SERVICE_ACCOUNT_KEY=
GMAIL_IMPERSONATE_EMAIL=admin-tools@zuddl.com
GMAIL_POLL_TIMEOUT_MS=120000
GMAIL_POLL_INTERVAL_MS=5000

# Local frontend
PORT=3000

# Processing
CONCURRENCY=1
MAX_SEARCH_RESULTS=10
PAGE_LOAD_TIMEOUT=30000
NETWORK_IDLE_WAIT=5000
HEADLESS=true

# Logging
LOG_LEVEL=info
